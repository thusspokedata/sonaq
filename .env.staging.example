# === Entorno ===
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://staging.sonaq.com.ar

# === Base de datos (Neon branch staging) ===
DATABASE_URL=postgresql://...staging-branch-connection-string...

# === Sanity ===
NEXT_PUBLIC_SANITY_DATASET=staging
NEXT_PUBLIC_SANITY_PROJECT_ID=<mismo que prod>
SANITY_API_TOKEN=<mismo token que prod, o uno específico de staging>

# === NextAuth ===
NEXTAUTH_URL=https://staging.sonaq.com.ar
NEXTAUTH_SECRET=<generar con: openssl rand -base64 32>

# === Resend ===
RESEND_API_KEY=<misma que prod>
EMAIL_FROM=staging@sonaq.com.ar
EMAIL_DRY_RUN=true
RESEND_AUDIENCE_ID=<crear audience separada "staging" en Resend, o usar la misma>

# === MercadoPago (modo TEST) ===
MP_ACCESS_TOKEN=TEST-...
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-...
MP_WEBHOOK_SECRET=<clave webhook modo prueba del panel de MP>

# === Banner staging ===
NEXT_PUBLIC_STAGING_BANNER=true
