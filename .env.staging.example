# === Entorno ===
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://staging.sonaq.com.ar

# === Base de datos (Neon branch staging) ===
DATABASE_URL="postgresql://REPLACE_WITH_NEON_STAGING_CONNECTION_STRING"

# === Sanity ===
NEXT_PUBLIC_SANITY_DATASET=staging
NEXT_PUBLIC_SANITY_PROJECT_ID="REPLACE_WITH_PROD_PROJECT_ID"
SANITY_API_TOKEN="REPLACE_WITH_SANITY_TOKEN"

# === NextAuth ===
NEXTAUTH_URL=https://staging.sonaq.com.ar
NEXTAUTH_SECRET="GENERATE_WITH: openssl rand -base64 32"

# === Resend ===
RESEND_API_KEY="REPLACE_WITH_RESEND_API_KEY"
EMAIL_FROM=staging@sonaq.com.ar
EMAIL_DRY_RUN=true
RESEND_AUDIENCE_ID="REPLACE_WITH_RESEND_AUDIENCE_ID"

# === MercadoPago (modo TEST) ===
MP_ACCESS_TOKEN="TEST-REPLACE_WITH_MP_TEST_ACCESS_TOKEN"
NEXT_PUBLIC_MP_PUBLIC_KEY="TEST-REPLACE_WITH_MP_TEST_PUBLIC_KEY"
MP_WEBHOOK_SECRET="REPLACE_WITH_MP_WEBHOOK_SECRET"

# === Banner staging ===
NEXT_PUBLIC_STAGING_BANNER=true
